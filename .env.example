# ─── Lila / PARKSystems Corporation — environment reference ──────────────────
# Copy to .env.local for local dev, or paste into Railway env vars for prod.
# Only the ones under "Required" must be set for the app to boot.

# ── Required ─────────────────────────────────────────────────────────────────

# Shared access password for the operator PWA. Leave empty and the app
# fails closed (every route 503s). Pick something long.
AUTH_PASSWORD=

# Postgres connection string. On Railway, attach the Postgres plugin and
# this auto-populates. Locally, point at any Postgres 13+.
DATABASE_URL=

# DeepSeek chat API key (https://platform.deepseek.com). Used by every
# background loop. Without it, the app runs in demo mode.
DEEPSEEK_API_KEY=


# ── Trading (optional — Alpaca) ──────────────────────────────────────────────
# If set, the Trades tab lights up, Lila runs her trade cycle, and
# TradingEngine executes pending picks during market hours.

ALPACA_API_KEY=
ALPACA_SECRET_KEY=
# Legacy names the code also accepts for compatibility. Don't set both.
# APCA_API_KEY_ID=
# APCA_API_SECRET_KEY=
# Set to "false" to trade the LIVE Alpaca account. Default: PAPER.
ALPACA_PAPER=true


# ── Bounty platforms (optional) ──────────────────────────────────────────────
# Each lights up its source on the Board tab and makes Tasker submit there.

SUPERTEAM_API_KEY=
NEYNAR_API_KEY=
CLAWTASKS_API_KEY=
# Solana or EVM address to receive non-Solana bounty payouts (where
# platforms support per-agent payout routing).
WALLET_ADDRESS=


# ── Scout autonomous bounty submitter (optional) ────────────────────────────
# When configured, Scout pulls sub-$500 GitHub-issue bounties from Gitcoin
# and Algora, drafts a full PR (markdown + unified diff), and Lila reviews
# every draft. With LILA_AUTO_SUBMIT=true she ALSO opens the PR upstream
# under the company GitHub account — no operator step required.
#
# GITHUB_TOKEN: a Personal Access Token (classic) on the company account
#   with the 'repo' scope. The token's owner becomes the fork+commit author.
#   Recommended: Settings → Developer settings → Personal access tokens
#                → Tokens (classic) → Generate. Grant 'repo' only.
# LILA_AUTO_SUBMIT: 'true' to actually open PRs. Anything else = drafts
#   queue in 'approved' state, Telegram pings the operator to copy/submit
#   manually. Use the env var as the kill switch — no code change needed.
GITHUB_TOKEN=
LILA_AUTO_SUBMIT=false


# ── Analyst picks → Telegram (optional) ──────────────────────────────────────
# When both are set, the Analyst mirrors every new picks batch to your Telegram
# channel/chat as a formatted brief (symbol, entry, target, stop, confidence,
# reason). Fires only when queued > 0, so silent days don't spam.
#
# Setup on mobile:
#   1. Open Telegram → search @BotFather → /newbot → follow prompts → copy token.
#   2. Create a channel (or use any chat), add the bot as admin with
#      "Post Messages" permission.
#   3. Post anything, then hit in a browser:
#      https://api.telegram.org/bot<TOKEN>/getUpdates
#      Chat ID is under result[*].channel_post.chat.id (negative for channels).

TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# Optional: if set, only this chat_id is allowed to DM Lila via Telegram.
# Defaults to TELEGRAM_CHAT_ID. For a personal deploy these are the same.
TELEGRAM_OWNER_CHAT_ID=
# Optional: random string set as Telegram's secret_token during setWebhook.
# When set, /api/telegram/webhook rejects calls missing the matching header.
TELEGRAM_WEBHOOK_SECRET=

# ── Sports betting odds (optional — Ceelo's edge gate) ─────────────────────
# Free 500 req/mo at https://the-odds-api.com/. Without this, Ceelo computes
# model lines from his Elo ratings but the |edge| ≥ 1.0 pt gate stays dark.
ODDS_API_KEY=

# ── Viewer subscriptions (optional — Gumroad-gated /viewer access) ─────────
# When set, the /viewer page is unlocked via a Gumroad license key. The
# operator UI at / stays password-gated under AUTH_PASSWORD as usual.
# Setup:
#   1. Create a paid product (one-time or subscription) on gumroad.com.
#   2. Enable "License keys" in the product settings.
#   3. Copy the product permalink (e.g. 'abc123' from gumroad.com/l/abc123)
#      into GUMROAD_PRODUCT_ID below.
#   4. Set VIEWER_COOKIE_SECRET to a random 32+ char string. This signs
#      the lila_viewer cookie — rotate it to invalidate every existing
#      viewer session at once.
#   5. (Optional) NEXT_PUBLIC_GUMROAD_URL is the public checkout link the
#      landing's "Buy pass" button + the /login member tab point at.
#      Default: https://gumroad.com/l/bfmoe
GUMROAD_PRODUCT_ID=
VIEWER_COOKIE_SECRET=
NEXT_PUBLIC_GUMROAD_URL=https://gumroad.com/l/bfmoe

# Gumroad webhook authenticator. Generate ANY long random string — Gumroad
# does not provide one. Examples:
#   openssl rand -hex 32
#   python -c "import secrets; print(secrets.token_hex(32))"
# Then put the SAME value in two places:
#   1. Railway env var:  GUMROAD_WEBHOOK_SECRET=<value>
#   2. Gumroad dashboard: your product → Advanced → Resource subscriptions
#      → URL = https://thepark.world/api/gumroad/webhook?secret=<value>
#      Tick at minimum: cancelled, refunded, ended, failed_charge.
# Without this set, /api/gumroad/webhook returns 503 and inbound pings are
# dropped — subscribers can still sign in via license verify, you just
# won't auto-deactivate cancelled subscriptions.
GUMROAD_WEBHOOK_SECRET=

# Public site URL — used to set OG/Twitter card metadataBase. Default is
# https://thepark.world. Override locally to e.g. http://localhost:3000.
NEXT_PUBLIC_SITE_URL=


# ── Broadcast (optional — Bluesky only) ──────────────────────────────────────
# When configured, BroadcastLoop posts a single update per hour — and ONLY
# when something notable happened (paid bounty, meaningful closed trade,
# newly approved report). Silent hours cost zero tokens.
#
# App password is from the Bluesky app:
#   Settings → Privacy and security → App Passwords → Add App Password.
# This is NOT your regular Bluesky login password.

BSKY_HANDLE=
BSKY_APP_PASSWORD=
# Override PDS host for self-hosted Bluesky servers. Default: bsky.social.
# BSKY_PDS=https://bsky.social


# ── Cadence knobs (optional, tune from Railway without redeploying) ──────────
# Every loop is time-gated; increasing these numbers cuts DeepSeek spend.

# Tasker step spacing (seconds). Default 30.
TASKER_STEP_SEC=30
# Min seconds between research cycles on the SAME pinned target. Bigger =
# fewer expensive research cycles, more room for cheap bounty work. Default 180.
RESEARCH_CYCLE_SEC=180
# Scout step spacing (seconds). One source-pull or one PR-draft per cycle.
# Smaller = faster bounty discovery + more LLM spend. Default 300.
SCOUT_RUN_SEC=300
# Lila proactive check-in interval (seconds). Default 300.
MANAGEMENT_CHECK_SEC=300
# Lila trade cycle interval (seconds). Default 900.
MANAGEMENT_TRADE_SEC=900
# Analyst step interval (minutes). Default 2.
ANALYST_STEP_MIN=2
# Broadcast interval (minutes). Default 60. Silent hours still skip posting.
BROADCAST_INTERVAL_MIN=60
# Server-side autonomy ticker interval (milliseconds). Default 30000.
AUTONOMY_TICK_MS=30000


# ── Budget (optional) ────────────────────────────────────────────────────────
# Hard cap on background-LLM spend per UTC day. Operator chat stream is
# exempt — Lila always replies to you.
# 0 disables the cap. Default 5.
DAILY_LLM_BUDGET_USD=5

# DeepSeek pricing in USD per 1M tokens. Override if pricing changes.
DEEPSEEK_PRICE_IN_PER_M=0.27
DEEPSEEK_PRICE_OUT_PER_M=1.10


# ── Switches (optional) ──────────────────────────────────────────────────────
# Master kill switch for the server-side 30s ticker. Default true.
ENABLE_AUTONOMY_TICKER=true
# Disable all public broadcasts. Default true.
ENABLE_BROADCAST=true
# Daily DELETE of stale log / usage / chat rows so Postgres stays small.
# Financial tables are never touched. Default true.
ENABLE_RETENTION=true
