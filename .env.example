# ─── Lila / PARKSystems Corporation — environment reference ──────────────────
# Copy to .env.local for local dev, or paste into Railway env vars for prod.
# Only the ones under "Required" must be set for the app to boot.

# ── Required ─────────────────────────────────────────────────────────────────

# Shared access password for the operator PWA. Leave empty and the app
# fails closed (every route 503s). Pick something long.
AUTH_PASSWORD=

# Postgres connection string. On Railway, attach the Postgres plugin and
# this auto-populates. Locally, point at any Postgres 13+.
DATABASE_URL=

# DeepSeek chat API key (https://platform.deepseek.com). Used by every
# background loop. Without it, the app runs in demo mode.
DEEPSEEK_API_KEY=


# ── Trading (optional — Alpaca) ──────────────────────────────────────────────
# If set, the Trades tab lights up, Lila runs her trade cycle, and
# TradingEngine executes pending picks during market hours.

ALPACA_API_KEY=
ALPACA_SECRET_KEY=
# Legacy names the code also accepts for compatibility. Don't set both.
# APCA_API_KEY_ID=
# APCA_API_SECRET_KEY=
# Set to "false" to trade the LIVE Alpaca account. Default: PAPER.
ALPACA_PAPER=true


# ── Bounty platforms (optional) ──────────────────────────────────────────────
# Each lights up its source on the Board tab and makes Tasker submit there.

SUPERTEAM_API_KEY=
NEYNAR_API_KEY=
CLAWTASKS_API_KEY=
# Solana or EVM address to receive non-Solana bounty payouts (where
# platforms support per-agent payout routing).
WALLET_ADDRESS=


# ── Forge / Scout / dev.to autonomous output pipeline (optional) ────────────
# Forge pulls funded $50-$200 GitHub-issue bounties from Algora tagged Bug or
# Feature, drafts a full PR (markdown + unified diff), and Lila reviews every
# draft. With LILA_AUTO_SUBMIT=true + GITHUB_TOKEN, github-pr.ts opens the PR
# upstream under the company GitHub account.
#
# Scout pulls remote Python automation / scraping / API roles from RemoteOK
# (public JSON API, no auth) and We Work Remotely (public RSS, no auth) — drafts
# a short application cover note the operator submits manually. When both
# sources are dry for SCOUT_DRY_HOURS, Scout drafts a technical tutorial
# instead. With DEVTO_API_KEY set, approved tutorials auto-publish to dev.to.
#
# GITHUB_TOKEN: a Personal Access Token (classic) on the company account
#   with the 'repo' scope. The token's owner becomes the fork+commit author.
#   Recommended: Settings → Developer settings → Personal access tokens
#                → Tokens (classic) → Generate. Grant 'repo' only.
# LILA_AUTO_SUBMIT: 'true' to actually open PRs. Anything else = drafts
#   queue in 'approved' state for the operator to copy/submit manually.
#   Use the env var as the kill switch — no code change needed.
GITHUB_TOKEN=
LILA_AUTO_SUBMIT=false

# DEVTO_API_KEY: dev.to API key (Settings → Extensions → DEV API Keys → Generate
#   API Key). When set, approved Scout tutorials auto-publish to dev.to. Without
#   it, tutorials sit in `articles` for manual copy-paste.
DEVTO_API_KEY=

# Scout tutorial topic rotation (optional, comma-separated). When set, Scout's
# tutorial fallback picks from this list instead of the built-in default seed.
# SCOUT_TUTORIAL_TOPICS=Async Python patterns,Fixing flaky scrapers,FastAPI rate-limit recipes


# ── Sports betting odds (optional — Ceelo's edge gate) ─────────────────────
# Free 500 req/mo at https://the-odds-api.com/. Without this, Ceelo computes
# model lines from his Elo ratings but the |edge| ≥ 1.0 pt gate stays dark.
ODDS_API_KEY=

# ── Sports ingestion (NBA → /theyield/sports/nba) ──────────────────────────
# Three independent feeds. All three are needed for the full picture:
#   API-Sports  — sharp anchor (pinnacle / circa) and line-move velocity.
#   ParlayAPI   — retail prices + ticket/money splits (DK/FD/MGM).
#   ProphetX    — peer-to-peer prediction market; provides overround.
# Without any of them the loop still runs but the matching signals stay null.
API_SPORTS_KEY=
PARLAY_API_KEY=
PROPHET_X_KEY=
ENABLE_SPORTS_LOOP=false
SPORTS_TICK_MS=60000

# ── Viewer subscriptions (optional — Gumroad-gated /viewer access) ─────────
# When set, the /viewer page is unlocked via a Gumroad license key. The
# operator UI at / stays password-gated under AUTH_PASSWORD as usual.
# Setup:
#   1. Create a paid product (one-time or subscription) on gumroad.com.
#   2. Enable "License keys" in the product settings.
#   3. GUMROAD_PRODUCT_ID accepts either the product's URL permalink (e.g.
#      'bfmoe' from gumroad.com/l/bfmoe) OR the unique product ID from the
#      product's settings page. It must match the product that issued the
#      license keys you're verifying — if you swap products, every key
#      issued under the old product will fail with "License does not exist
#      for the provided product."
#   4. Set VIEWER_COOKIE_SECRET to a random 32+ char string. This signs
#      the lila_viewer cookie — rotate it to invalidate every existing
#      viewer session at once.
#   5. (Optional) NEXT_PUBLIC_GUMROAD_URL is the public checkout link the
#      landing's "Buy pass" button + the /login member tab point at.
#      Default: https://gumroad.com/l/bfmoe
GUMROAD_PRODUCT_ID=
VIEWER_COOKIE_SECRET=
NEXT_PUBLIC_GUMROAD_URL=https://gumroad.com/l/bfmoe

# Gumroad webhook secret (OPTIONAL). Cancellation handling is covered by
# the reverify poller in lib/gumroad-reverify.ts — it picks one active
# viewer per autonomy tick and re-runs Gumroad's license verify. No env
# var needed for that; it just runs whenever GUMROAD_PRODUCT_ID is set.
#
# This webhook is only useful if you also wire up Gumroad's Resource
# Subscriptions (their UI removed the toggle; you have to register via
# their API + an OAuth token), and even then the poller is the source of
# truth. Generate any long random string and put it on both sides:
#   openssl rand -hex 32
#   1. Railway env var:  GUMROAD_WEBHOOK_SECRET=<value>
#   2. Gumroad webhook URL: https://thepark.world/api/gumroad/webhook?secret=<value>
GUMROAD_WEBHOOK_SECRET=

# Public site URL — used to set OG/Twitter card metadataBase. Default is
# https://thepark.world. Override locally to e.g. http://localhost:3000.
NEXT_PUBLIC_SITE_URL=


# ── Broadcast (optional — Bluesky only) ──────────────────────────────────────
# When configured, BroadcastLoop posts a single update per hour — and ONLY
# when something notable happened (paid bounty, meaningful closed trade,
# newly approved report). Silent hours cost zero tokens.
#
# App password is from the Bluesky app:
#   Settings → Privacy and security → App Passwords → Add App Password.
# This is NOT your regular Bluesky login password.

BSKY_HANDLE=
BSKY_APP_PASSWORD=
# Override PDS host for self-hosted Bluesky servers. Default: bsky.social.
# BSKY_PDS=https://bsky.social


# ── Cadence knobs (optional, tune from Railway without redeploying) ──────────
# Every loop is time-gated; increasing these numbers cuts DeepSeek spend.

# Tasker step spacing (seconds). Default 30.
TASKER_STEP_SEC=30
# Min seconds between research cycles on the SAME pinned target. Bigger =
# fewer expensive research cycles, more room for cheap bounty work. Default 180.
RESEARCH_CYCLE_SEC=180
# Scout step spacing (seconds). One gig-pull or one pitch-draft per cycle.
# Smaller = faster gig discovery + more LLM spend. Default 300.
SCOUT_RUN_SEC=300
# Hours of empty RemoteOK/WWR fetches before Scout switches to drafting
# a tutorial article. Default 24. Set to 0 for verification (forces tutorial
# mode on the next cycle).
SCOUT_DRY_HOURS=24
# Forge step spacing (seconds). One Algora-pull or one PR-draft per cycle.
# Same shape as SCOUT_RUN_SEC. Default 300.
FORGE_RUN_SEC=300
# Analyst step interval (minutes). Default 2.
ANALYST_STEP_MIN=2
# Broadcast interval (minutes). Default 60. Silent hours still skip posting.
BROADCAST_INTERVAL_MIN=60
# Server-side autonomy ticker interval (milliseconds). Default 30000.
AUTONOMY_TICK_MS=30000


# ── Budget (optional) ────────────────────────────────────────────────────────
# Hard cap on background-LLM spend per UTC day. Operator chat stream is
# exempt — Lila always replies to you.
# 0 disables the cap. Default 5.
DAILY_LLM_BUDGET_USD=5

# DeepSeek pricing in USD per 1M tokens. Override if pricing changes.
DEEPSEEK_PRICE_IN_PER_M=0.27
DEEPSEEK_PRICE_OUT_PER_M=1.10


# ── Switches (optional) ──────────────────────────────────────────────────────
# Master kill switch for the server-side 30s ticker. Default true.
ENABLE_AUTONOMY_TICKER=true
# Disable all public broadcasts. Default true.
ENABLE_BROADCAST=true
# Daily DELETE of stale log / usage / chat rows so Postgres stays small.
# Financial tables are never touched. Default true.
ENABLE_RETENTION=true


# ── The Bazaar (optional, gates the /bazaar surface) ─────────────────────────
# Private encrypted agent labor market settled in $LDGR on Solana. All
# Bazaar features stay dormant until both BAZAAR_BOT_SECRET and SOLANA_RPC_URL
# are set; partial config is fine for local development.

# HMAC shared secret between Next.js and the matrix-nio bot + MCP servers.
# Generate with `openssl rand -base64 64`. Rotate quarterly.
BAZAAR_BOT_SECRET=

# Bearer tokens for MCP scope routing. Operator/Lila tokens get elevated
# scope; per-agent tokens are issued at agent creation.
BAZAAR_OPERATOR_TOKEN=
BAZAAR_LILA_TOKEN=

# Public Element URL — linked from the /bazaar wallet card.
NEXT_PUBLIC_ELEMENT_URL=https://element.bazaar.parksystems.app

# ── Solana / $LDGR ───────────────────────────────────────────────────────────
# Cluster: 'devnet' (default) or 'mainnet-beta'. Stay on devnet until
# the audit + multisig conditions in programs/ldgr/README.md are met.
SOLANA_CLUSTER=devnet
SOLANA_RPC_URL=
# Optional Helius API key — if set we route RPC through Helius. Otherwise
# we fall back to the public devnet endpoint.
HELIUS_API_KEY=

# Filled in after `anchor build && anchor deploy`.
LDGR_ESCROW_PROGRAM_ID=
# Filled in after running programs/ldgr/migrations/deploy.ts.
LDGR_MINT=
# Devnet-only: base58 secret key of the mint authority. Remove before
# mainnet — mainnet mint authority must be a multisig.
LDGR_MINT_AUTHORITY_SECRET=

# Lila bot's Solana moderator key. Base58 secret key held server-side; the
# bot has signing power on every escrow PDA but cannot mint.
LILA_BOT_SOLANA_SECRET=
LILA_BOT_SOLANA_PUBKEY=

# ── Matrix / Synapse ─────────────────────────────────────────────────────────
SYNAPSE_SERVER_NAME=bazaar.parksystems.app
MATRIX_HOMESERVER_URL=https://bazaar.parksystems.app
LILA_BOT_USER=@lila:bazaar.parksystems.app
LILA_BOT_PASSWORD=
LILA_BOT_DEVICE=BAZAAR-LILA-1
