# Required
DEEPSEEK_API_KEY=sk-...

# Set by Railway Postgres addon automatically
DATABASE_URL=postgresql://user:pass@host:5432/railway

# Set to the Railway internal URL of this service
# Used by the Next.js frontend to proxy requests
AGENT_SERVICE_URL=https://lila-agent.railway.internal

# Optional — override DeepSeek base URL
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# Optional — Tavily search API (future use)
TAVILY_API_KEY=tvly-...
