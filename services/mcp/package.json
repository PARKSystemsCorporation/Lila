{
  "name": "bazaar-mcp",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -b skills hiring",
    "typecheck": "tsc -p skills/tsconfig.json --noEmit && tsc -p hiring/tsconfig.json --noEmit",
    "start:skills": "node skills/dist/index.js",
    "start:hiring": "node hiring/dist/index.js",
    "dev:skills": "tsx skills/src/index.ts",
    "dev:hiring": "tsx hiring/src/index.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "pg": "^8.13.3",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.14.9",
    "@types/pg": "^8.11.10",
    "tsx": "^4.16.2",
    "typescript": "^5.7.0"
  }
}
